{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All-in-One Editable PowerPoint Deck Brief",
  "type": "object",
  "required": ["route", "audience", "goal", "deliverable", "editability"],
  "properties": {
    "route": {
      "type": "string",
      "enum": ["create", "edit", "reconstruct", "audit-repair"]
    },
    "modifiers": {
      "type": "array",
      "items": { "type": "string", "enum": ["template", "academic", "business"] },
      "uniqueItems": true
    },
    "audience": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "presentation_context": { "type": "string" },
    "language": { "type": "string", "default": "auto" },
    "slide_count": { "type": ["integer", "string"], "default": "auto" },
    "tone": { "type": "string", "default": "clear and professional" },
    "deliverable": {
      "type": "object",
      "required": ["format", "editable"],
      "properties": {
        "format": { "const": "pptx" },
        "editable": { "const": true },
        "output_path": { "type": "string" },
        "extras": {
          "type": "array",
          "items": { "type": "string", "enum": ["pdf", "slide-images", "speaker-notes", "source-ledger", "plan", "qa-report"] },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "editability": {
      "type": "object",
      "required": ["policy", "full_slide_raster_allowed"],
      "properties": {
        "policy": { "const": "native-first" },
        "full_slide_raster_allowed": { "const": false },
        "native_required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "raster_allowed": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "brand": {
      "type": "object",
      "properties": {
        "template_path": { "type": "string" },
        "reference_deck_path": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "fonts": { "type": "array", "items": { "type": "string" } },
        "logo_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path_or_url", "kind"],
        "properties": {
          "path_or_url": { "type": "string" },
          "kind": { "type": "string" },
          "notes": { "type": "string" },
          "confidential": { "type": "boolean", "default": false }
        },
        "additionalProperties": true
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
