{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All-in-One Editable PowerPoint Slide Plan",
  "type": "object",
  "required": ["deck_title", "route", "canvas", "assets", "slides"],
  "properties": {
    "deck_title": { "type": "string", "minLength": 1 },
    "route": {
      "type": "string",
      "enum": ["create", "edit", "reconstruct", "audit-repair"]
    },
    "modifiers": {
      "type": "array",
      "items": { "type": "string", "enum": ["template", "academic", "business"] },
      "uniqueItems": true
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height", "unit"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "const": "in" }
      }
    },
    "style": {
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "fonts": { "type": "array", "items": { "type": "string" } },
        "template_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "kind", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "enum": ["supplied", "search", "imagegen", "derived"] },
          "kind": { "type": "string", "enum": ["photo", "illustration", "screenshot", "texture", "complex-figure", "background"] },
          "status": { "type": "string", "enum": ["planned", "ready", "rejected"] },
          "path": { "type": "string" },
          "source_url": { "type": "string" },
          "license": { "type": "string" },
          "prompt": { "type": "string" },
          "alt_text": { "type": "string" },
          "target_slides": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
          "reusable": { "type": "boolean", "default": false },
          "composition": { "type": "string" },
          "avoid": { "type": "array", "items": { "type": "string" } }
        },
        "allOf": [
          {
            "if": { "properties": { "source": { "const": "imagegen" } }, "required": ["source"] },
            "then": { "required": ["prompt", "alt_text"] }
          },
          {
            "if": { "properties": { "status": { "const": "ready" } }, "required": ["status"] },
            "then": { "required": ["path"] }
          }
        ],
        "additionalProperties": true
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_no", "title", "purpose", "takeaway", "layout", "objects"],
        "properties": {
          "slide_no": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "takeaway": { "type": "string", "minLength": 1 },
          "layout": { "type": "string", "minLength": 1 },
          "speaker_notes": { "type": "string" },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "objects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "type", "content", "materialization", "editable"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "type": {
                  "type": "string",
                  "enum": ["text", "bullets", "image", "chart", "table", "shape", "connector", "diagram", "icon", "quote", "code", "equation", "video"]
                },
                "role": { "type": "string" },
                "content": {},
                "materialization": { "type": "string", "enum": ["native", "raster", "hybrid"] },
                "editable": { "type": "boolean" },
                "replaceable": { "type": "boolean" },
                "asset_id": { "type": "string" },
                "raster_reason": { "type": "string" },
                "source_refs": { "type": "array", "items": { "type": "string" } },
                "allow_overlap": { "type": "boolean", "default": false },
                "bbox": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "w": { "type": "number", "exclusiveMinimum": 0 },
                    "h": { "type": "number", "exclusiveMinimum": 0 }
                  },
                  "required": ["x", "y", "w", "h"]
                },
                "style": { "type": "object", "additionalProperties": true }
              },
              "allOf": [
                {
                  "if": { "properties": { "materialization": { "const": "native" } }, "required": ["materialization"] },
                  "then": { "properties": { "editable": { "const": true } } }
                },
                {
                  "if": { "properties": { "type": { "const": "image" } }, "required": ["type"] },
                  "then": { "required": ["asset_id", "replaceable"] }
                }
              ],
              "additionalProperties": true
            }
          },
          "qa_notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
