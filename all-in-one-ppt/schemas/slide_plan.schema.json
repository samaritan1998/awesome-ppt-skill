{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All-in-One PPT Slide Plan",
  "type": "object",
  "required": ["deck_title", "route", "slides"],
  "properties": {
    "deck_title": { "type": "string" },
    "route": { "type": "string" },
    "style": {
      "type": "object",
      "properties": {
        "aspect_ratio": { "type": "string", "default": "16:9" },
        "theme": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "fonts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_no", "title", "takeaway", "layout", "objects"],
        "properties": {
          "slide_no": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "takeaway": { "type": "string" },
          "layout": { "type": "string" },
          "speaker_notes": { "type": "string" },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "objects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "content"],
              "properties": {
                "id": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["text", "title", "bullets", "image", "chart", "table", "shape", "diagram", "quote", "code", "equation"]
                },
                "content": {},
                "editable": { "type": "boolean", "default": true },
                "bbox": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "w": { "type": "number" },
                    "h": { "type": "number" }
                  },
                  "required": ["x", "y", "w", "h"]
                }
              },
              "additionalProperties": true
            }
          },
          "qa_notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
